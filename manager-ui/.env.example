VITE_API_URL=http://localhost:9000
VITE_API_TOKEN=test
VITE_FETCH_INTERVAL=10000
VITE_LIMIT_SYNCS_HISTORY=50
VITE_SEARCH_DEBOUNCE_SECONDS=2000

# Auth dev mode (frontend only): live | mock | forbidden
#   live      = real SSO flow (GET /auth/me)
#   mock      = skip SSO, logged in as a mock user
#   forbidden = show the access-denied page
VITE_AUTH_MODE=live
# Optional JSON to override the mock user:
# VITE_AUTH_MOCK_USER={"upn":"test","name":"test","email":"test@test.com"}
